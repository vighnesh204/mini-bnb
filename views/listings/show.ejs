<% layout("/layouts/boilerplate") %>
<div class="container mt-5 mb-5">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <div class="text-center mb-4">
        <h2 class="listing-page-title">Listing Details</h2>
      </div>
      
      <img src="<%= listing.image %>" class="listing-detail-image mb-3" alt="<%= listing.title %>">
      
      <div class="card listing-info-card">
        <div class="card-body listing-detail-body">
          <h5 class="listing-detail-title"><%= listing.title %></h5>
          
          <p class="listing-detail-description"><%= listing.description %></p>
          
          <div class="price-badge mb-3">
            ₹ <%= listing.price.toLocaleString("en-IN") %>
          </div>
          
          <p class="listing-detail-location"><%= listing.location %></p>
          <p class="listing-detail-country"><%= listing.country %></p>
          
          <div class="listing-actions mt-4">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
              <button type="submit" class="btn btn-danger">Delete</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
