<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
      <center>
    <h1>Edit yourListing</h1>
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <input type="text" name="title" value="<%= listing.title %>"><br><br>
        <textarea type="text" name="description"><%= listing.description %></textarea> <br><br>
        <input type="number" name="price" value="<%= listing.price %>"> <br><br>
        <input type="text" name="location" value="<%= listing.location %>"> <br><br>
        <input type="text" name="country" value="<%= listing.country %>"> <br><br>
        <button type="submit">Edit Listing</button>
    </form>
    </center>
</body>
</html>